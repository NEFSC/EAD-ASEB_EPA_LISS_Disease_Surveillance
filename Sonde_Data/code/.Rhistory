reshape2::melt(id.vars = c("date_collected", "Site","month","year"),
measure.vars = c("Salinity","Temp(C)_Field","pH","pCO2 out (matm)","HCO3 out (mmol/kgSW)","CO3 out (mmol/kgSW)","CO2 out (mmol/kgSW)","Aragonite_Sat","Total CO2 (ppm)"))
